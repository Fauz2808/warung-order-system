#!/bin/sh
# Pre-push hook — jalan otomatis sebelum git push
# Install: git config core.hooksPath .githooks

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo "${YELLOW}🔍 Pre-push check dimulai...${NC}"
echo ""

# ── Cek branch yang di-push ───────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ── Frontend build ────────────────────────────────────
echo "${YELLOW}📦 Build frontend...${NC}"
cd frontend || exit 1

NEXT_PUBLIC_API_URL=https://warung-order-system-production.up.railway.app \
NEXT_PUBLIC_SOCKET_URL=https://warung-order-system-production.up.railway.app \
NEXT_PUBLIC_APP_URL=https://carracoffee.my.id \
npm run build 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "${RED}❌ Frontend build GAGAL — push dibatalkan.${NC}"
  echo "Perbaiki error di atas dulu sebelum push."
  echo ""
  exit 1
fi

cd ..

# ── Backend syntax check ──────────────────────────────
echo ""
echo "${YELLOW}🔧 Cek syntax backend...${NC}"
FAILED=0
for f in backend/src/routes/*.js backend/src/middleware/*.js backend/index.js; do
  node --check "$f" 2>&1
  if [ $? -ne 0 ]; then
    echo "${RED}❌ Syntax error di: $f${NC}"
    FAILED=1
  fi
done

if [ $FAILED -ne 0 ]; then
  echo ""
  echo "${RED}❌ Backend syntax check GAGAL — push dibatalkan.${NC}"
  exit 1
fi

echo ""
echo "${GREEN}✅ Semua check passed! Push ke '$BRANCH' dilanjutkan...${NC}"
echo ""
exit 0
