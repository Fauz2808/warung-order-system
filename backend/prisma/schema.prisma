// Prisma Schema — Warung Order System
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// ⚠️  LOCAL DEV: ganti ke provider = "sqlite"
// ⚠️  PRODUCTION (Railway): provider = "postgresql"
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Kategori menu — bisa di-CRUD oleh kasir/admin
model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique   // "coffee", "teh-susu" — dipakai di Menu.category
  label     String             // "Coffee", "Teh Susu" — nama tampilan, bisa diubah
  emoji     String   @default("☕")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Menu {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Int         // dalam Rupiah, contoh: 25000
  category    String
  imageUrl    String?
  isAvailable Boolean     @default(true)
  stock       Int?        // null = unlimited; 0 = habis
  hasTemperatureOption Boolean @default(false)
  hasAdditionalEspresso  Boolean @default(false)
  additionalEspressoPrice Int    @default(3000)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  modifierGroups MenuModifierGroup[]
}

// ─── Modifier System ──────────────────────────────────

// Grup modifier: "Ukuran", "Suhu", "Tambahan Topping", dll
model ModifierGroup {
  id          Int                 @id @default(autoincrement())
  name        String              // "Ukuran", "Suhu", "Tambahan"
  required    Boolean             @default(false)   // wajib dipilih customer
  multiSelect Boolean             @default(false)   // bisa pilih lebih dari 1 opsi
  minSelect   Int                 @default(0)
  maxSelect   Int?                // null = tidak ada batas (untuk multiSelect)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  options     ModifierOption[]
  menuLinks   MenuModifierGroup[]
}

// Opsi dalam grup: "Small", "Medium", "Large" / "Hot", "Iced"
model ModifierOption {
  id          Int            @id @default(autoincrement())
  groupId     Int
  group       ModifierGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String         // "Small", "Hot", "Oat Milk"
  priceAdd    Int            @default(0)    // tambahan harga (bisa 0)
  isDefault   Boolean        @default(false)
  isAvailable Boolean        @default(true)
  sortOrder   Int            @default(0)
  orderItemModifiers OrderItemModifier[]
}

// Junction: menu ↔ modifier group (many-to-many)
model MenuModifierGroup {
  menuId    Int
  menu      Menu          @relation(fields: [menuId], references: [id], onDelete: Cascade)
  groupId   Int
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  @@id([menuId, groupId])
}

// Modifier yang dipilih customer saat order — snapshot
model OrderItemModifier {
  id          Int             @id @default(autoincrement())
  orderItemId Int
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionId    Int?
  option      ModifierOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  groupName   String          // snapshot nama grup
  optionName  String          // snapshot nama opsi
  priceAdd    Int             // snapshot harga tambahan
}

model Table {
  id         Int      @id @default(autoincrement())
  number     Int      @unique  // nomor meja, unik
  floor      Int      @default(1)  // lantai 1, 2, dst
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  orders     Order[]
  sessions   TableSession[]
}

// Bon per meja (open tab) — mengelompokkan beberapa order dalam satu kunjungan.
// Customer bisa terus menambah order selama sesi "open"; kasir menutup + bayar sekaligus.
model TableSession {
  id            Int       @id @default(autoincrement())
  tableId       Int
  table         Table     @relation(fields: [tableId], references: [id])
  status        String    @default("open")   // "open" | "closed"
  customerName  String?
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  callRequestedAt DateTime?               // customer menekan "Panggil Kasir" (null = tidak ada panggilan)
  isPaid        Boolean   @default(false)
  paymentMethod String?                       // "cash" | "qris" | "split" — diisi saat tutup bon
  notes         String?                       // catatan pembayaran, mis. "[Pisah Bayar: Cash X + QRIS Y]"
  orders        Order[]
}

model Order {
  id           Int         @id @default(autoincrement())
  dailyNumber  Int         @default(0)
  tableId      Int
  table        Table       @relation(fields: [tableId], references: [id])
  status       String      @default("pending")
  // status: "pending" | "preparing" | "done" | "cancelled"
  orderType    String      @default("dine-in")  // "dine-in" | "take-away"
  totalAmount  Int         // total harga dalam Rupiah
  notes        String?     // catatan tambahan dari customer
  customerName String?     // nama customer, opsional (diisi kasir)
  isPaid           Boolean     @default(false)  // false = belum bayar, true = sudah lunas
  paymentMethod    String      @default("cash")  // "cash" | "qris" | "split"
  paymentLocation  String?     // "kasir" | "meja" — ditentukan kasir saat selesaikan order
  sessionId    Int?        // bon/open-tab yang menaungi order ini (null = order lama / take-away lepas)
  session      TableSession? @relation(fields: [sessionId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

// User — kasir & owner
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt hash
  role      String   @default("kasir")  // "owner" | "kasir"
  name      String?  // nama tampilan (opsional)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pengaturan warung — singleton (id selalu 1)
model Settings {
  id               Int      @id @default(1)
  businessName     String   @default("Warung Kita")
  businessTagline  String   @default("Pesan mudah, nikmati santai")
  openTime         String   @default("08:00")
  closeTime        String   @default("22:00")
  isForceClose     Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model OrderItem {
  id       Int     @id @default(autoincrement())
  orderId  Int
  order    Order   @relation(fields: [orderId], references: [id])
  menuId   Int?
  menu     Menu?   @relation(fields: [menuId], references: [id])
  menuName String  @default("")
  quantity Int
  price    Int     // snapshot harga dasar (belum termasuk modifier)
  notes    String?
  additionalEspressoShots Int @default(0)
  additionalEspressoPrice Int @default(0)
  modifiers OrderItemModifier[]
}
