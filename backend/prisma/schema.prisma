// Prisma Schema — Warung Order System
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// ⚠️  LOCAL DEV: ganti ke provider = "sqlite"
// ⚠️  PRODUCTION (Railway): provider = "postgresql"
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Kategori menu — bisa di-CRUD oleh kasir/admin
model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique   // "coffee", "teh-susu" — dipakai di Menu.category
  label     String             // "Coffee", "Teh Susu" — nama tampilan, bisa diubah
  emoji     String   @default("☕")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Menu {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Int         // dalam Rupiah, contoh: 25000
  category    String      // "signature" | "coffee" | "americano" | "slow-bar" | "non-coffee" | "foods" | "additional"
  imageUrl    String?
  isAvailable Boolean     @default(true)
  stock       Int?        // null = unlimited; 0 = habis
  hasTemperatureOption Boolean @default(false)  // true = tampilkan opsi Hot/Ice
  hasAdditionalEspresso  Boolean @default(false)   // toggle additional espresso shot
  additionalEspressoPrice Int    @default(3000)     // harga per shot dalam Rupiah
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Table {
  id         Int      @id @default(autoincrement())
  number     Int      @unique  // nomor meja, unik
  floor      Int      @default(1)  // lantai 1, 2, dst
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  orders     Order[]
}

model Order {
  id           Int         @id @default(autoincrement())
  tableId      Int
  table        Table       @relation(fields: [tableId], references: [id])
  status       String      @default("pending")
  // status: "pending" | "preparing" | "done" | "cancelled"
  orderType    String      @default("dine-in")  // "dine-in" | "take-away"
  totalAmount  Int         // total harga dalam Rupiah
  notes        String?     // catatan tambahan dari customer
  customerName String?     // nama customer, opsional (diisi kasir)
  isPaid       Boolean     @default(false)  // false = belum bayar, true = sudah lunas
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

// User — kasir & owner
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt hash
  role      String   @default("kasir")  // "owner" | "kasir"
  name      String?  // nama tampilan (opsional)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pengaturan warung — singleton (id selalu 1)
model Settings {
  id           Int      @id @default(1)
  openTime     String   @default("08:00")   // format "HH:mm"
  closeTime    String   @default("22:00")   // format "HH:mm"
  isForceClose Boolean  @default(false)     // tutup paksa (override jam)
  updatedAt    DateTime @updatedAt
}

model OrderItem {
  id       Int     @id @default(autoincrement())
  orderId  Int
  order    Order   @relation(fields: [orderId], references: [id])
  menuId   Int?    // nullable — null jika menu sudah dihapus
  menu     Menu?   @relation(fields: [menuId], references: [id])
  menuName String  @default("")  // snapshot nama menu saat order dibuat
  quantity Int
  price    Int     // snapshot harga saat order dibuat
  notes    String? // catatan per item, contoh: "tidak pakai pedas"
  additionalEspressoShots Int @default(0)   // jumlah shot yang dipesan
  additionalEspressoPrice Int @default(0)   // snapshot harga per shot saat order
}
